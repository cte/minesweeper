{
  "name": "minesweeper-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "play": "tsx src/cli.ts",
    "score": "tsx src/score.ts",
    "score:holdout": "tsx src/score.ts --benchmark bench/holdout.json",
    "check": "tsc --noEmit",
    "patchloop:init": "node scripts/patchloop.mjs init",
    "patchloop:record": "node scripts/patchloop.mjs record",
    "patchloop:trial": "node scripts/patchloop.mjs trial",
    "patchloop:loop": "node scripts/patchloop.mjs loop",
    "patchloop:codex-edit": "node scripts/patchloop.mjs codex-edit",
    "patchloop:loop:codex": "node scripts/patchloop.mjs loop-codex",
    "patchloop:runs": "node scripts/patchloop.mjs runs",
    "patchloop:activate-run": "node scripts/patchloop.mjs activate-run",
    "patchloop:dashboard": "node scripts/patchloop.mjs dashboard",
    "patchloop:dashboard:dev": "node scripts/patchloop.mjs dashboard --dev"
  },
  "dependencies": {
    "@patchloop/core": "file:../patchloop/packages/core"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
